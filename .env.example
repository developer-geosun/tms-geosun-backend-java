SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

MYSQL_DATABASE=tms_auth
MYSQL_USER=tms_user
MYSQL_PASSWORD=tms_password
MYSQL_ROOT_PASSWORD=root
# Порт MySQL на хості при docker compose (щоб не займати 3306, якщо вже працює локальний MySQL)
MYSQL_HOST_PORT=3307

DB_URL=jdbc:mysql://localhost:3306/tms_auth?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USER=tms_user
DB_PASSWORD=tms_password

JWT_SECRET=replace-me-with-strong-secret-of-at-least-32-characters
JWT_ISSUER=
JWT_AUDIENCE=
JWT_EXPIRES_SECONDS=900
JWT_REFRESH_EXPIRES_SECONDS=604800

EMAIL_VERIFICATION_EXPIRES_SECONDS=86400
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=no-reply@example.com

RATE_LIMIT_LOGIN_MAX_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=900
RATE_LIMIT_RESEND_VERIFICATION_SECONDS=60
RATE_LIMIT_REFRESH_MAX_REQUESTS=30
RATE_LIMIT_REFRESH_WINDOW_SECONDS=60
RATE_LIMIT_REGISTER_MAX_PER_WINDOW=30

TOKEN_CLEANUP_RETENTION_DAYS=30
TOKEN_CLEANUP_CRON=0 0 2 * * *
